# Database Configuration
DATABASE_URL=postgresql://user:password@db/db

# Redis Configuration
REDIS_URL=redis://redis:6379

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# First Superuser
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=changeme
FIRST_SUPERUSER_NAME=Admin
FIRST_SUPERUSER_PHONE=+966500000000

# SendGrid Email Service (REQUIRED for email functionality)
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Your Company Name

# Twilio SMS Service (REQUIRED for SMS/OTP functionality)
# Get credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_MESSAGING_SERVICE_SID=your-messaging-service-sid

# Backblaze B2 Object Storage (REQUIRED for file uploads)
# Get credentials from: https://secure.backblaze.com/app_keys.htm
BACKBLAZE_KEY_ID=your-backblaze-key-id
BACKBLAZE_APPLICATION_KEY=your-backblaze-application-key
BACKBLAZE_BUCKET_NAME=your-bucket-name
BACKBLAZE_BUCKET_ID=

# Checkout.com Payment Gateway (REQUIRED for payments)
# Get credentials from: https://dashboard.checkout.com/
CHECKOUT_SECRET_KEY=your-checkout-secret-key
CHECKOUT_PUBLIC_KEY=your-checkout-public-key
CHECKOUT_API_URL=https://api.sandbox.checkout.com

# Frontend URLs (for email links)
FRONTEND_URL=http://localhost:3000  # Mobile app
ADMIN_PANEL_URL=http://localhost:3001  # Admin panel
PROVIDERS_PANEL_URL=http://localhost:3002  # Providers panel

# Rate Limiting Configuration
# OTP Rate Limits - Control how many OTP requests can be made
OTP_MAX_ATTEMPTS=3  # Maximum OTP requests per time window (default: 3)
OTP_TIME_WINDOW_SECONDS=3600  # Time window in seconds (default: 3600 = 1 hour)
OTP_EXPIRY_SECONDS=300  # OTP code expiry time in seconds (default: 300 = 5 minutes)
OTP_VERIFICATION_TOKEN_EXPIRY_SECONDS=600  # Verification token expiry (default: 600 = 10 minutes)

# Email Verification Rate Limits
EMAIL_VERIFICATION_MAX_ATTEMPTS=3  # Maximum email verification requests per time window
EMAIL_VERIFICATION_TIME_WINDOW_SECONDS=3600  # Time window in seconds (default: 1 hour)

# Password Reset Rate Limits
PASSWORD_RESET_MAX_ATTEMPTS=3  # Maximum password reset requests per time window
PASSWORD_RESET_TIME_WINDOW_SECONDS=3600  # Time window in seconds (default: 1 hour)

# Project Configuration
PROJECT_NAME=Safe Algo Tourism
API_V1_STR=/api/v1

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Taskiq Configuration
# Set to 'true' to enable verbose logging for taskiq workers (default: false)
TASKIQ_VERBOSE_LOGGING=false

# Taskiq Scheduled Task Cron Schedules
# Format: "minute hour day month day_of_week" (standard cron format)
TASKIQ_TRIP_REMINDER_CRON=0 9 * * *      # Daily at 9 AM - Send reminders 24h before trip starts
TASKIQ_REVIEW_REMINDER_CRON=0 20 * * *   # Daily at 8 PM - Request reviews after trip ends
TASKIQ_PAYMENT_REMINDER_CRON=0 */6 * * * # Every 6 hours - Remind users with pending payments
