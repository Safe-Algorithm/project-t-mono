{
  "expo": {
    "name": "rihla-app",
    "slug": "rihla",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Rihla-logo.png",
    "scheme": "rihlaapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/Rihla-logo-transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#13519c"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.safealgo.rihlaapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Rihla-logo.png",
        "backgroundColor": "#13519c"
      },
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.safealgo.sa",
              "pathPrefix": "/payment-callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "rihlaapp"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/Rihla-logo.png",
          "color": "#13519c"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f998b35d-5781-43cf-8591-fee070fbd5bb"
      }
    },
    "owner": "rihlas-organization"
  }
}
